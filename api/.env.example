# =============================================================================
# Codion API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────

# Secret key used to sign JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET

# JWT expiry for access tokens (minutes)
JWT_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────────────────

# SQLite (local dev)
DATABASE_URL=sqlite+aiosqlite:///./codion.db

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/codion

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add in Google Console:
#   http://localhost:8000/auth/google/callback   (dev)
#   https://api.yourdomain.com/auth/google/callback  (prod)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth2 ─────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL to add in GitHub:
#   http://localhost:8000/auth/github/callback   (dev)
#   https://api.yourdomain.com/auth/github/callback  (prod)

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
